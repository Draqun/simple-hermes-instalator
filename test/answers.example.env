# answers.example.env — non-interactive answers for install-hermes-mikrus.sh
#
#   bash install-hermes-mikrus.sh --answers test/answers.example.env
#
# Every ANS_<NAME> maps to a prompt. Enable flags are yes/no. Secrets can also
# be exported in the environment instead of stored here (keep this file 600 if
# it holds real secrets).

# --- Capability / general ---------------------------------------------------
# (No answer needed for the capability check; use --force on the CLI to bypass.)

# --- AI provider ------------------------------------------------------------
# Pick by MENU INDEX (robust for non-interactive; labels with spaces need quoting):
#   1 OpenRouter   2 Anthropic   3 Google Gemini   4 OpenAI   5 NVIDIA (NIM)
#   6 DeepSeek     7 xAI Grok    8 z.ai/GLM         9 Kimi     10 MiniMax
#   11 Ollama Cloud   12 Hugging Face   13 Custom OpenAI-compatible
#   14 Other native (advanced)   15 Nous Portal / skip
ANS_PROVIDER=1
# Model string. OpenRouter: "vendor/model"; Anthropic: bare "claude-opus-4-6";
# NVIDIA: a NIM model id (see build.nvidia.com); custom: whatever the endpoint wants.
ANS_MODEL=anthropic/claude-sonnet-4.6
# Provide the API-key env var matching your provider (only the relevant one is read):
ANS_OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
#ANS_ANTHROPIC_API_KEY=sk-ant-xxxx
#ANS_GEMINI_API_KEY=AIzaSy...
#ANS_NVIDIA_API_KEY=nvapi-xxxx
#ANS_DEEPSEEK_API_KEY=...
#ANS_XAI_API_KEY=...
# For index 13 "Custom OpenAI-compatible endpoint" (provider: custom):
#ANS_CUSTOM_BASE_URL=http://127.0.0.1:8000/v1
#ANS_CUSTOM_API_KEY=            # leave empty for keyless local servers

# --- Version to install -----------------------------------------------------
# Menu index: 1 = latest release tag (recommended), 2 = bleeding edge
# (agent main / WebUI master), 3 = custom (then set ANS_AGENT_REF / ANS_WEBUI_REF).
ANS_VERSION_CHOICE=1
#ANS_AGENT_REF=v2026.7.7.2      # only for choice 3 (tag or 7-40 hex commit)
#ANS_WEBUI_REF=v0.52.41         # only for choice 3 (tag or branch)

# --- Continue checkpoint (after agent install) ------------------------------
# Y proceeds to configuration non-interactively; N stops after installing the agent.
ANS_CONTINUE_CONFIG=Y

# --- Browser tools ----------------------------------------------------------
# Heavy on RAM; leave 'no' on Mikrus 3.0 (2 GB).
ANS_ENABLE_BROWSER_TOOLS=no

# --- Messaging bridges (all optional) ---------------------------------------
ANS_ENABLE_TELEGRAM=no
#ANS_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#ANS_TELEGRAM_ALLOWED_USERS=111111111
#ANS_TELEGRAM_HOME_CHANNEL=

ANS_ENABLE_SLACK=no
#ANS_SLACK_BOT_TOKEN=xoxb-...
#ANS_SLACK_APP_TOKEN=xapp-...
#ANS_SLACK_ALLOWED_USERS=

ANS_ENABLE_WHATSAPP=no
#ANS_WHATSAPP_ALLOWED_USERS=15551234567

ANS_ENABLE_EMAIL=no
#ANS_EMAIL_ADDRESS=hermes@gmail.com
#ANS_EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
#ANS_EMAIL_IMAP_HOST=imap.gmail.com
#ANS_EMAIL_IMAP_PORT=993
#ANS_EMAIL_SMTP_HOST=smtp.gmail.com
#ANS_EMAIL_SMTP_PORT=587
#ANS_EMAIL_ALLOWED_USERS=you@example.com

ANS_ENABLE_TEAMS=no
#ANS_TEAMS_CLIENT_ID=
#ANS_TEAMS_CLIENT_SECRET=
#ANS_TEAMS_TENANT_ID=common
#ANS_TEAMS_ALLOWED_USERS=

ANS_ENABLE_GOOGLECHAT=no
#ANS_GOOGLE_CHAT_PROJECT_ID=
#ANS_GOOGLE_CHAT_SUBSCRIPTION_NAME=
#ANS_GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=
#ANS_GOOGLE_CHAT_ALLOWED_USERS=

# --- WebUI ------------------------------------------------------------------
# Leave empty to auto-generate a strong password (printed once during install).
ANS_HERMES_WEBUI_PASSWORD=
# Public port for the reverse proxy (an allocated Mikrus port, e.g. 20000+ID):
#ANS_PUBLIC_PORT=20123
